CF_ACCOUNT_ID=
CF_D1_DATABASE_ID=
CF_API_TOKEN=

# Admin auth
# Use a long random string (at least 32 chars)
ADMIN_SESSION_SECRET=
# Optional cookie lifetime in seconds (default: 28800 = 8 hours)
ADMIN_SESSION_TTL_SECONDS=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Optional public domain or custom domain for served files
# Example: https://pub-xxxx.r2.dev or https://cdn.yourdomain.com
R2_PUBLIC_URL=
# Optional max upload size (bytes). Default: 104857600 (100MB)
R2_MAX_UPLOAD_BYTES=