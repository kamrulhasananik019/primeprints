# Cloudflare D1 API credentials (required for direct D1 access from Next.js)
CF_ACCOUNT_ID=
CF_D1_DATABASE_ID=
CF_API_TOKEN=

# Admin panel login
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_SESSION_SECRET=replace-with-long-random-secret

# Optional: Next.js Site URL (used for canonical URLs, social sharing)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudflare R2 (Optional - for image/file uploads)
R2_ACCOUNT_ID=
R2_BUCKET=primeprints-assets
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Optional public delivery URL for R2 files
# Example: https://pub-xxxx.r2.dev or https://assets.yourdomain.com
R2_PUBLIC_URL=
# Optional max upload size in bytes (default: 104857600 = 100MB)
R2_MAX_UPLOAD_BYTES=104857600

# Legacy: Cloudflare D1 (No longer used - keeping for reference)
# CF_ACCOUNT_ID=
# CF_D1_DATABASE_ID=
# CF_API_TOKEN=
